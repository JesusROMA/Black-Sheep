# BLACKSHEEP — configuración Apache para IONOS Hosting Business

DirectoryIndex index.html

RewriteEngine On

# Forzar HTTPS (compatible con el proxy SSL de IONOS, evita bucles)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# La landing usa /api/demo — lo enrutamos al script PHP
RewriteRule ^api/demo/?$ api/demo.php [L]

# Cache de assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
</IfModule>

# Compresión
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
